{
  "$schema": "https://docs.openclaw.ai/openclaw.schema.json",
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": {
        "source": "env",
        "provider": "default",
        "id": "OPENCLAW_GATEWAY_TOKEN"
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/openclaw-workspaces/orchestrator",
      "model": {
        "primary": "openai/gpt-4o-mini"
      },
      "heartbeat": { "every": "30m" },
      "maxConcurrent": 4
    },
    "list": [
      {
        "id": "orchestrator",
        "default": true,
        "workspace": "~/openclaw-workspaces/orchestrator",
        "tools": {
          "allow": ["read", "write", "edit", "exec", "process", "session_status"],
          "deny": ["browser", "canvas", "nodes", "cron"]
        }
      },
      {
        "id": "builder",
        "workspace": "~/openclaw-workspaces/builder",
        "model": { "primary": "openai/gpt-4o-mini" },
        "tools": {
          "allow": ["read", "write", "edit", "exec", "session_status"],
          "deny": ["browser", "canvas", "nodes", "cron"]
        }
      }
    ]
  }
}
